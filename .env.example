# Public Supabase project URL — exposed to the client bundle.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key — safe for the client; RLS gates access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Public origin for magic-link redirect (set per env: dev / preview / prod).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI API key — used by the OCR worker (added in a later change).
OPENAI_API_KEY=
